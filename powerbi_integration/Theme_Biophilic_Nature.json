{
  "name": "Biophilic Architecture Horizon",
  "dataColors": [
    "#2D6A4F",
    "#C05A46",
    "#D38E70",
    "#0E1F16",
    "#1E382A",
    "#64748B",
    "#4f46e5",
    "#10b981"
  ],
  "background": "#FAF9F6",
  "foreground": "#0E1F16",
  "tableAccent": "#2D6A4F",
